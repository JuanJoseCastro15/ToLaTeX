# ==========================================
# 1. VISUAL STUDIO CODE
# ==========================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace
.history/

# ==========================================
# 2. VISUAL STUDIO (Comunidad/Enterprise)
# ==========================================
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Resultados de compilación y binarios
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Caché y bases de datos locales
*.ncb
*.sdf
*.opensdf
*.sqlite
ipch/

# ==========================================
# 3. JUPYTER NOTEBOOK & PYTHON
# ==========================================
# Checkpoints de Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Archivos temporales de Jupyter y guardado automático
*.ipynb_checkpoints

# Entornos virtuales y caché de Python (muy común al usar Jupyter)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# ==========================================
# 4. SWIFT & XCODE
# ==========================================
# Swift Package Manager (SPM)
.build/
Packages/
.swiftpm/xcode/xcuserdata/
.swiftpm/xcode/workspace.xcworkspace/

# Datos de usuario de Xcode (evita conflictos de ventanas y estados)
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/

# Compilación y artefactos de Swift/iOS/macOS
DerivedData/
build/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM/

# ==========================================
# 5. SISTEMA OPERATIVO (General)
# ==========================================
# macOS (Crucial si trabajas con Swift)
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
